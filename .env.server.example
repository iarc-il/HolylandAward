# Environment template for the SERVER stacks (Portainer):
#   docker-compose.dev-server.yml  (dev/staging)
#   docker-compose.prod.yml        (production)
#
# These are the ONLY runtime variables the server needs. The VITE_* values
# (API base URL, Clerk publishable key, Google Maps key) are NOT runtime vars —
# they are baked into the frontend bundle at CI build time from GitHub Secrets.
# See DEPLOYMENT.md.
#
# In Portainer, set these per-stack under "Environment variables" (do not commit
# real secrets to the repo).

# --- Database ---
POSTGRES_USER=holyland_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=holyland_award

# --- Backend (Clerk) ---
CLERK_SECRET_KEY=sk_...

# --- CORS / app origin (backend reads this for allowed origins) ---
# Dev/staging: https://holyland-dev.<SERVER_IP>.sslip.io
# Production:  https://holylandaward.iarc.org
FRONTEND_URL=https://holylandaward.iarc.org

# --- Optional image tag overrides (defaults are set in the compose files) ---
# BACKEND_IMAGE=ghcr.io/iarc-il/holylandaward/backend:latest
# FRONTEND_IMAGE=ghcr.io/iarc-il/holylandaward/frontend:latest
